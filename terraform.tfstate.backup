      "module": "module.logging",
      "mode": "data",
      "type": "archive_file",
      "name": "lambda_zip",
      "provider": "provider[\"registry.terraform.io/hashicorp/archive\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "exclude_symlink_directories": null,
            "excludes": null,
            "id": "854ef18b905d0113b57cafa080cc9a1d718de59c",
            "output_base64sha256": "UiWreo9ZbCaUByVwjHd3c3aWQu2h1inxi2ly6REkH0I=",
            "output_base64sha512": "gbQGCDJF67warSebVgeSFsllJny6Tv8kzLyLOozI41mQd2nyrpJ/3KGnBrHtGKnOW698i8VdARV2PPFJkBaiZQ==",
            "output_file_mode": null,
            "output_md5": "d4a5689c9961ca69386fbb418c761959",
            "output_path": "modules/logging/lambda_function.zip",
            "output_sha": "854ef18b905d0113b57cafa080cc9a1d718de59c",
            "output_sha256": "5225ab7a8f596c26940725708c777773769642eda1d629f18b6972e911241f42",
            "output_sha512": "81b406083245ebbc1aad279b56079216c965267cba4eff24ccbc8b3a8cc8e359907769f2ae927fdca1a706b1ed18a9ce5baf7c8bc55d0115763cf1499016a265",
            "output_size": 460,
            "source": [
              {
                "content": "import json\nimport boto3\nimport os\n\nsns = boto3.client('sns')\n\ndef handler(event, context):\n    print(json.dumps(event))\n    for record in event.get('Records', []):\n        bucket  = record['s3']['bucket']['name']\n        key     = record['s3']['object']['key']\n        message = f\"New CloudTrail log: s3://{bucket}/{key}\"\n        sns.publish(\n            TopicArn=os.environ['SNS_TOPIC_ARN'],\n            Subject=\"CloudTrail Log Delivered\",\n            Message=message,\n        )\n    return {'statusCode': 200}\n",
                "filename": "lambda_function.py"
              }
            ],
            "source_content": null,
            "source_content_filename": null,
            "source_dir": null,
            "source_file": null,
            "type": "zip"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0
        }
      ]
    },
